{
  "manifest_version": 3,
  "name": "Gitlift",
  "version": "1.0.0",
  "description": "Automatically push your accepted coding solutions to GitHub. Supports LeetCode, GeeksforGeeks, and HackerRank.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.geeksforgeeks.org/*",
    "https://www.hackerrank.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/content/common.js", "src/content/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.geeksforgeeks.org/problems/*"],
      "js": ["src/content/common.js", "src/content/geeksforgeeks.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.hackerrank.com/challenges/*"],
      "js": ["src/content/common.js", "src/content/hackerrank.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/inject.js"],
      "matches": [
        "https://*.geeksforgeeks.org/*",
        "https://www.hackerrank.com/*"
      ]
    }
  ]
}
